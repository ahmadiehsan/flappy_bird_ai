{
    "files.exclude": {
        "**/.venv": true,
        "**/__pycache__": true,
        "**/.mypy_cache": true,
        "**/.idea": true,
        "**/.ruff_cache": true
    },
    "search.exclude": {
        "**/uv.lock": true
    },
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "pyproject.toml": "uv.lock",
        ".pre-commit-config.yaml": ".env, .checkmake.ini, .opencommitignore",
    },
    "cSpell.words": [
        "ahmadiehsan",
        "blit",
        "metas"
    ]
}
